#define _USE_MATH_DEFINES
#include <GL/glut.h>
#include <GL/glu.h>
#include <cmath>

int signalState = 0;
float barrierY = -0.25;
float carX = -1.2;
float pedY = -1.0;

void drawLineDDA(float x1,float y1,float x2,float y2) {

    float dx = x2 - x1;
    float dy = y2 - y1;

    float steps = (fabs(dx) > fabs(dy)) ? fabs(dx) : fabs(dy);

    float xInc = dx / steps;
    float yInc = dy / steps;

    float x = x1;
    float y = y1;

    glBegin(GL_POINTS);
    for(int i=0;i<=steps;i++) {
        glVertex2f(x,y);
        x += xInc;
        y += yInc;
    }
    glEnd();
}

void drawLineBresenham(float x1,float y1,float x2,float y2) {

    int X1 = (int)((x1 + 1) * 500);
    int Y1 = (int)((y1 + 1) * 500);
    int X2 = (int)((x2 + 1) * 500);
    int Y2 = (int)((y2 + 1) * 500);

    int dx = abs(X2 - X1);
    int dy = abs(Y2 - Y1);

    int sx = (X1 < X2) ? 1 : -1;
    int sy = (Y1 < Y2) ? 1 : -1;

    int err = dx - dy;

    glBegin(GL_POINTS);
    while(true) {

        float xf = (X1 / 500.0f) - 1.0f;
        float yf = (Y1 / 500.0f) - 1.0f;

        glVertex2f(xf,yf);

        if(X1 == X2 && Y1 == Y2) break;

        int e2 = 2 * err;

        if(e2 > -dy) { err -= dy; X1 += sx; }
        if(e2 < dx)  { err += dx; Y1 += sy; }
    }
    glEnd();
}

void update(int v) {

    if(signalState == 0 && barrierY < 0.05)
        barrierY += 0.01;

    if(signalState == 1 && barrierY > -0.25)
        barrierY -= 0.01;

    if(signalState == 1) {
        carX += 0.01;
    } else {
        if(carX < -0.17)
            carX += 0.005;
    }

    if(carX > 1.2) carX = -1.2;

    if(signalState == 0) {
        pedY += 0.01;
        if(pedY > 0.6) pedY = -1.0;
    }

    glutPostRedisplay();
    glutTimerFunc(16, update, 0);
}
void drawRoad() {

    glColor3f(0.2,0.2,0.2);
    glRectf(-1,-0.2,1,0.2);

    glColor3f(1,1,1);
    for(float i=-0.05;i<=0.05;i+=0.02){
        glRectf(i,-0.2,i+0.01,0.2);
    }
}

void drawTrafficLight() {

    glColor3f(0.3,0.3,0.3);
    glRectf(0.8,0.2,0.85,0.7);

    if(signalState==0) glColor3f(1,0,0);
    else glColor3f(0.3,0,0);
    glRectf(0.78,0.65,0.87,0.75);

    if(signalState==1) glColor3f(0,1,0);
    else glColor3f(0,0.3,0);
    glRectf(0.78,0.5,0.87,0.6);
}

void drawLamp() {

   
    glColor3f(0.2,0.2,0.2);

    for(float i = -0.75; i <= -0.72; i += 0.002) {
        drawLineBresenham(i, -0.2, i, 0.55);
    }


 
    glColor3f(1,1,1);
    drawLineDDA(-0.73, 0.50, -0.60, 0.50);

    
    drawLineBresenham(-0.73, 0.48, -0.60, 0.48);


    drawLineBresenham(-0.60, 0.50, -0.60, 0.48);

    drawLineBresenham(-0.60,0.48,-0.58,0.48);
    drawLineBresenham(-0.58,0.48,-0.58,0.44);
    drawLineBresenham(-0.58,0.44,-0.60,0.44);
    drawLineBresenham(-0.60,0.44,-0.60,0.48);

    // Bulb
    glColor3f(1,1,0.3);
    glBegin(GL_POLYGON);
    for(int i=0;i<20;i++){
        float a = i * 2 * M_PI / 20;
        glVertex2f(-0.59 + 0.03*cos(a), 0.44 + 0.03*sin(a));
    }
    glEnd();

    // Glow
    glColor4f(1,1,0,0.25);
    glBegin(GL_POLYGON);
    for(int i=0;i<20;i++){
        float a = i * 2 * M_PI / 20;
        glVertex2f(-0.59 + 0.08*cos(a), 0.44 + 0.08*sin(a));
    }
    glEnd();
}


void drawBarrierGate() {

    if(signalState == 1) return;

    glColor3f(1,0.8,0);

    glRectf(-0.05, barrierY, 0.05, barrierY + 0.05);
}


void drawCar() {

    glPushMatrix();
    glTranslatef(carX,-0.05,0);

    glColor3f(0,0,1);
    glRectf(-0.12,-0.05,0.12,0.05);

    glColor3f(0,0,0);
    glRectf(-0.1,-0.08,-0.05,-0.05);
    glRectf(0.05,-0.08,0.1,-0.05);

    glPopMatrix();
}


void drawPedestrian() {

    if(signalState != 0) return;

    glPushMatrix();
    glTranslatef(0,pedY,0);

    glColor3f(1,0.8,0.6);
    glBegin(GL_POLYGON);
    for(int i=0;i<20;i++){
        float a = i*2*M_PI/20;
        glVertex2f(0.02*cos(a),0.02*sin(a)+0.1);
    }
    glEnd();

    glColor3f(0,0,0);
    glBegin(GL_LINES);
        glVertex2f(0,0.08); glVertex2f(0,0);
        glVertex2f(0,0.06); glVertex2f(-0.03,0.03);
        glVertex2f(0,0.06); glVertex2f(0.03,0.03);
        glVertex2f(0,0); glVertex2f(-0.02,-0.05);
        glVertex2f(0,0); glVertex2f(0.02,-0.05);
    glEnd();

    glPopMatrix();
}
void display() {

    glClearColor(0,0.6,0.9,1);
    glClear(GL_COLOR_BUFFER_BIT);
    glLoadIdentity();

    glPointSize(3.0); 

    drawRoad();
    drawTrafficLight();
    drawLamp();
    drawBarrierGate();
    drawCar();
    drawPedestrian();

    glutSwapBuffers();
}

void keyboard(unsigned char key,int x,int y) {
    if(key=='r') signalState=0;
    if(key=='g') signalState=1;
}


void init() {
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    gluOrtho2D(-1,1,-1,1);
    glMatrixMode(GL_MODELVIEW);

    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
}


int main(int argc,char** argv) {

    glutInit(&argc,argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB);
    glutInitWindowSize(900,600);
    glutCreateWindow("Zebra Crossing - Final Algorithm Version");

    init();

    glutDisplayFunc(display);
    glutKeyboardFunc(keyboard);
    glutTimerFunc(0,update,0);

    glutMainLoop();
}

